---
import type { MarkdownLayoutProps } from "astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import Layout from "./Layout.astro";
import { SITE } from "@/config";

// DELETE THE STARLIGHT CSS IMPORTS FROM HERE
// They are not exposed by the package exports

type Props = MarkdownLayoutProps<{ title: string }>;
const { frontmatter } = Astro.props;
const headings = Astro.props.headings ?? [];
---

<Layout title={`${frontmatter.title} | ${SITE.title}`}>
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/katex@0.16.0/dist/katex.min.css"
  />

  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout pb-16 pt-6">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-start">
      <section id="about" class="app-prose mx-auto min-w-0 max-w-4xl prose-img:border-0 lg:max-w-none">
        <h1>{frontmatter.title}</h1>
        <slot />
      </section>
      <div class="lg:sticky lg:top-28">
        <TableOfContents headings={headings} />
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style is:global>
  /* 2. Manually provide the variables Starlight components look for */
  :root {
    --sl-color-accent: var(--color-accent, #007acc);
    --sl-color-bg-inline-code: var(--color-fill, #f4f4f4);
  }

  /* Style the Tabs so they don't look like plain bullet points */
  starlight-tabs {
    display: block;
    max-width: 100%;
    min-width: 0;
    margin: 1.5rem 0;
  }

  starlight-tabs div[role="tabpanel"] {
    min-width: 0;
  }
  
  .starlight-aside {
    padding: 1rem 1.1rem;
    margin: 1.5rem 0;
    border-left: 0.25rem solid var(--sl-color-accent);
    background-color: color-mix(in srgb, var(--color-muted) 75%, transparent);
    border-radius: 0 1rem 1rem 0;
  }
</style>
