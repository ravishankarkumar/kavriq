---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
type BlogData = { featured?: boolean };
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";

const posts: CollectionEntry<"blog">[] = await getCollection<"blog">("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(p => (p.data as unknown as BlogData).featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class="grid gap-8 pt-8 pb-8 lg:grid-cols-[minmax(0,1.45fr)_minmax(280px,0.9fr)] lg:items-end">
      <div class="max-w-4xl">
        <p class="tech-label text-sm font-semibold tracking-[0.22em] text-accent uppercase">
          KAVRIQ
        </p>
        <h1 class="mt-5 max-w-5xl text-5xl font-semibold tracking-tight sm:text-6xl lg:text-7xl">
          AI education with systems-level clarity.
        </h1>
        <p class="mt-5 max-w-2xl text-lg text-foreground/72">
          Led by curiosity. Built for engineers who want depth, precision, and
          durable intuition across modern AI systems.
        </p>
      </div>

      <div class="surface-panel rounded-3xl border border-border p-6">
        <p class="tech-label text-xs font-semibold tracking-[0.18em] text-foreground/55 uppercase">
          Focus
        </p>
        <ul class="mt-4 space-y-3 text-sm text-foreground/72">
          <li>First-principles explanations without trend-chasing.</li>
          <li>Python-first implementation paths for serious learners.</li>
          <li>Coverage across models, agents, tooling, and evaluation.</li>
        </ul>
        <div class="mt-6 flex flex-wrap gap-3 text-sm">
          <LinkButton class="rounded-full border border-border px-4 py-2 hover:border-accent hover:text-accent" href="/agentic-ai">
            Agentic AI
          </LinkButton>
        </div>
      </div>
    </section>

    <section class="grid gap-6 border-y border-border py-6 text-sm text-foreground/70 sm:grid-cols-3">
      <div>
        <p class="tech-label text-xs font-semibold tracking-[0.18em] uppercase text-foreground/50">
          What this is
        </p>
        <p class="mt-2 leading-6">
          A systems-first learning platform for engineers building real AI systems.
        </p>
      </div>
      <div>
        <p class="tech-label text-xs font-semibold tracking-[0.18em] uppercase text-foreground/50">
          How it's built
        </p>
        <p class="mt-2 leading-6">
          Systems thinking, rigorous breakdowns, and implementation-first learning for builders.
        </p>
      </div>
      <div>
        <p class="tech-label text-xs font-semibold tracking-[0.18em] uppercase text-foreground/50">
          What you'll find
        </p>
        <p class="mt-2 leading-6">
          From essays to 
          <LinkButton
            class="ms-1 underline decoration-1 decoration-foreground/30 underline-offset-4 transition-colors hover:text-accent hover:decoration-accent/45"
            href="https://github.com/ravishankarkumar/kavriq-examples"
          >
          code 
          </LinkButton>
          to system visualizations — learn by seeing and building.
        </p>
      </div>
    </section>

    {
      featuredPosts.length > 0 && (
        <section id="featured" class="py-10">
          <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <p class="tech-label text-xs font-semibold tracking-[0.18em] uppercase text-foreground/50">
                Selected Reading
              </p>
              <h2 class="mt-2 text-3xl font-semibold tracking-tight">
                Start with the clearest entry points.
              </h2>
            </div>
            <p class="max-w-xl text-sm leading-6 text-foreground/65">
              A few high-signal pieces that show how KAVRIQ approaches AI systems:
              serious, structured, and implementation-aware.
            </p>
          </div>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
