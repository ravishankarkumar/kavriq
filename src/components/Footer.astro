---
import type { HTMLAttributes } from "astro/types";
import Socials from "./Socials.astro";

const currentYear = new Date().getFullYear();

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;
---

<footer
  class:list={["app-layout", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div
    class:list={[
      "mt-10 flex flex-col gap-4 border-t border-border py-6 sm:flex-row-reverse sm:items-center sm:justify-between",
    ]}
  >
    <Socials />
    <div class="flex flex-col items-center gap-2 text-sm text-foreground/70 sm:items-start">
      <nav aria-label="Footer" class="flex flex-wrap justify-center gap-x-4 gap-y-2 sm:justify-start">
        <a href="/about" class="transition-colors hover:text-foreground">About</a>
        <a href="/privacy" class="transition-colors hover:text-foreground">Privacy</a>
        <a href="/disclaimer" class="transition-colors hover:text-foreground">Disclaimer</a>
      </nav>
      <div class="flex flex-col items-center whitespace-nowrap sm:flex-row">
        <span>Copyright &#169; 2024-{currentYear}</span>
        <span class="hidden sm:inline">&nbsp;|&nbsp;</span>
        <span>All rights reserved.</span>
      </div>
    </div>
  </div>
</footer>
