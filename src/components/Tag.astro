---
type Props = {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
};

const { tag, tagName, size = "lg" } = Astro.props;
---

<li class="list-none">
  <a
    href={`/tags/${tag}/`}
    transition:name={tag}
    class:list={[
      "surface-panel inline-flex items-center gap-1 rounded-full border border-border px-3 py-1.5 text-foreground/75 transition-colors hover:border-accent/40 hover:text-accent",
      "focus-visible:border-accent/40 focus-visible:text-accent",
      { "text-sm": size === "sm" },
      { "text-lg": size === "lg" },
    ]}
  >
    <span
      aria-hidden="true"
      class:list={[
        "font-mono opacity-65",
        { "text-xs": size === "sm" },
        { "text-base": size === "lg" },
      ]}
    >
      #
    </span>
    {tagName}
  </a>
</li>
