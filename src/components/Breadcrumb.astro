---
// Remove current url path and remove trailing slash if exists
const currentUrlPath = Astro.url.pathname.replace(/\/+$/, "");

// Get url array from path
// eg: /tags/tailwindcss => ['tags', 'tailwindcss']
const breadcrumbList = currentUrlPath.split("/").slice(1);

// Custom mapping to clean up folder names (Optional but recommended)
const labelMapping: Record<string, string> = {
  "agentic-ai": "Agentic AI",
  "prerequisite": "Prerequisites",
  "foundations": "Foundations",
  "agent-architecture": "Agent Architecture",
  "planning-systems": "Planning Systems",
  "tool-use-protocols": "Tool Use Protocols",
  "memory-systems-rag": "Memory Systems & RAG",
  "multi-agent": "Multi-Agent Systems",
  "computer-use-vision": "Computer Use & Vision",
  "guardrails-safety": "Guardrails & Safety",
  "evaluation-metrics": "Evaluation Metrics",
  "high-perf-engineering": "High-Perf Engineering",
  "agent-internals": "Agent Internals",
  "capstone-projects": "Capstone Projects",

  //
  "ml-essentials": "ML Essentials",

  // Module 0
  "setting-up": "Setting Up Your Environment",

  // Module 1 — Agentic AI Overview
  "introduction-to-agents": "Introduction to Agents",
  "llm-basics-for-agents": "LLM Basics for Agents",
  "core-agentic-principles": "Core Agentic Principles",

  // Module 2 — Foundations
  "what-is-an-agent": "What is an Agent?",
  "cognitive-architecture": "Cognitive Architecture",
  "inference-time-compute": "Inference-Time Compute",
  "modern-llm-primitives": "Modern LLM Primitives",

  // Module 3 — Agent Architecture
  "the-anatomy-of-an-agent": "The Anatomy of an Agent",
  "the-perception-layer": "The Perception Layer",
  "working-memory-and-the-scratchpad": "Working Memory & Scratchpad",
  "the-planner-reasoner": "The Planner / Reasoner",
  "tool-manager": "The Tool Manager",
  "execution-engine": "The Execution Engine",
  "observation-processor": "The Observation Processor",
  "reflection-and-termination": "Reflection & Termination",

  // Module 4 — Planning Systems
  "why-planning-matters": "Why Planning Matters",
  "react": "ReAct: Reason + Act",
  "chain-of-thought": "Chain-of-Thought Planning",
  "tree-of-thought": "Tree-of-Thought Reasoning",
  "execution-graphs": "Execution Graphs",
  "langgraph": "Building Agents with LangGraph",

  // Module 5 — Tool Use Protocols
  "why-tools": "Why Tools Make Agents Powerful",
  "designing-reliable-tools": "Designing Reliable Tools",
  "mcp": "Model Context Protocol (MCP)",
  "mcp-rust": "Building an MCP Server in Rust",

  // Module 6 — Memory Systems
  "memory-hierarchy": "Memory Hierarchy of Agents",
  "episodic-memory": "Episodic Memory",
  "semantic-memory": "Semantic Memory",
  "procedural-memory": "Procedural Memory",
  "agentic-rag": "Agentic RAG",
  "multi-hop": "Multi-Hop Retrieval",

  // Module 7 — Multi-Agent
  "why-multi-agent": "Why Multi-Agent Systems Exist",
  "centralised-coordination": "Manager–Worker Coordination",
  "handoff-swarm": "Handoff Pattern (Swarm)",
  "debate-pattern": "Debate Pattern",
  "a2a-agent-to-agent": "Agent-to-Agent Communication (A2A)",

  // Module 8 — Computer Use
  "computer-use-agents": "Computer Use Agents",
  "gui-navigation": "GUI Navigation",
  "visual-grounding": "Visual Grounding",

  // Module 9 — Guardrails & Safety
  "prompt-injection": "Prompt Injection Attacks",
  "tool-permissions": "Tool Permission Systems",
  "human-in-the-loop": "Human-in-the-Loop",
  "sandboxing": "Sandboxing Agent Execution",

  // Module 10 — Evaluation Metrics
  "why-evaluation-is-hard": "Why Agent Evaluation Is Hard",
  "llm-judge": "LLM-as-a-Judge",
  "trajectory-eval": "Trajectory Evaluation",
  "building-eval-pipelines": "Building Evaluation Pipelines",

  // Module 11 — High Performance Engineering
  "small-model": "The Small Model Strategy",
  "small-model-using-rust": "Using Rust for Agent Infrastructure",
  "observability": "Observability for Agents",

  // Module 12 — Agent Internals
  "why-build-agent-runtime": "Why Build Your Own Agent Runtime",
  "state-machine": "Designing a Simple Agent State Machine",
  "tool-calling": "Implementing Tool Calling",
  "time-travel": "Adding Time-Travel Debugging",
  "langgraph-alternative": "A 300-Line LangGraph Alternative",

  // Module 13 — Capstone Projects
  "computer-use-researcher": "The Computer-Use Researcher",
  "multi-agent-coding": "The Multi-Agent Coding Pipeline",
  "privacy-first-butler": "The Privacy-First Local Butler",
};

// if breadcrumb is Home > Posts > 1 <etc>
// replace Posts with Posts (page number)
if (breadcrumbList[0] === "posts") {
  breadcrumbList.splice(0, 2, `Posts (page ${breadcrumbList[1] || 1})`);
}

// if breadcrumb is Home > Tags > [tag] > [page] <etc>
// replace [tag] > [page] with [tag] (page number)
if (breadcrumbList[0] === "tags" && !isNaN(Number(breadcrumbList[2]))) {
  breadcrumbList.splice(
    1,
    3,
    `${breadcrumbList[1]} ${Number(breadcrumbList[2]) === 1 ? "" : "(page " + breadcrumbList[2] + ")"}`
  );
}
---

<nav class="app-layout mt-8 mb-1" aria-label="breadcrumb">
  <ul
    class="font-light [&>li]:inline [&>li:not(:last-child)>a]:hover:opacity-100"
  >
    <li>
      <a href="/" class="opacity-80">Home</a>
      <span aria-hidden="true" class="opacity-80">&raquo;</span>
    </li>
    <!-- {
      breadcrumbList.map((breadcrumb, index) =>
        index + 1 === breadcrumbList.length ? (
          <li>
            <span
              class:list={["capitalize opacity-75", { lowercase: index > 0 }]}
              aria-current="page"
            >
              {/* make the last part lowercase in Home > Tags > some-tag */}
              {decodeURIComponent(breadcrumb)}
            </span>
          </li>
        ) : (
          <li>
            <a href={`/${breadcrumb}/`} class="capitalize opacity-70">
              {breadcrumb}
            </a>
            <span aria-hidden="true">&raquo;</span>
          </li>
        )
      )
    } -->
    {
      breadcrumbList.map((breadcrumb, index) => {
        // BUILD THE CUMULATIVE PATH
        // This joins all previous segments to create the correct nested link
        const breadcrumbPath = `/${breadcrumbList.slice(0, index + 1).join("/")}/`;

        // Use mapping if exists, otherwise fallback to title-casing the slug
        const displayName =
          labelMapping[breadcrumb] ||
          decodeURIComponent(breadcrumb).replace(/-/g, " ");
        const isLast = index + 1 === breadcrumbList.length;

        return isLast ? (
          <li>
            <span
              class:list={["capitalize opacity-75", { lowercase: index > 0 }]}
              aria-current="page"
            >
              {displayName}
            </span>
          </li>
        ) : (
          <li>
            <a href={breadcrumbPath} class="capitalize opacity-70">
              {displayName}
            </a>
            <span aria-hidden="true">&raquo;</span>
          </li>
        );
      })
    }
  </ul>
</nav>
