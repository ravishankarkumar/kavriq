---
import { SOCIALS } from "@/constants";
import LinkButton from "./LinkButton.astro";
---

<div class="flex flex-wrap items-center gap-2">
  {
    SOCIALS.map(social => (
      <LinkButton
        href={social.href}
        class="surface-panel rounded-xl border border-border p-2 text-foreground/70 transition-colors hover:text-foreground sm:p-2"
        title={social.linkTitle}
      >
        <social.icon class="inline-block size-5 fill-transparent stroke-current stroke-2" />
        <span class="sr-only">{social.linkTitle}</span>
      </LinkButton>
    ))
  }
</div>
